<script src="/js/app.js"></script>
<script>
// Brute force demo
window.bruteForceDemo = async function() {
  const log  = document.getElementById('brute-log');
  const counter2 = document.getElementById('attempt-counter-2');
  log.textContent = '';

  const creds = [
    { u: 'admin', p: 'password' },
    { u: 'admin', p: '123456' },
    { u: 'admin', p: 'admin' },
    { u: 'admin', p: 'admin123' },
    { u: 'alice', p: 'alice' },
    { u: 'bob',   p: 'bob' },
    { u: 'admin', p: 'qwerty' },
    { u: 'bender',p: 'bender' },
    { u: 'eve',   p: 'password123' },
    { u: 'admin', p: 'letmein' }
  ];

  for (let i = 0; i < creds.length; i++) {
    const { u, p } = creds[i];
    const res = await fetch('/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: u, password: p })
    });
    const data = await res.json();
    counter2.textContent = data.attempts || (i + 1);

    if (data.success) {
      log.textContent += `[${i+1}] ✅ SUCCESS: ${u}:${p} → ${data.user.role}\n`;
    } else {
      log.textContent += `[${i+1}] ❌ FAIL:    ${u}:${p}\n`;
    }
    log.scrollTop = log.scrollHeight;
    await new Promise(r => setTimeout(r, 50)); // tiny delay for visibility
  }

  document.getElementById('attempt-counter').textContent = counter2.textContent;
};

// Sync attempt counters
setInterval(async () => {
  const res = await fetch('/login/attempts').catch(() => null);
  if (!res) return;
  const data = await res.json().catch(() => null);
  if (!data) return;
  const c1 = document.getElementById('attempt-counter');
  const c2 = document.getElementById('attempt-counter-2');
  if (c1) c1.textContent = data.attempts;
  if (c2) c2.textContent = data.attempts;
}, 3000);
</script>
</body>
