        <!-- File Upload -->
        <div class="vuln-card" id="upload-section">
          <div class="card-header">
            <div class="card-icon icon-orange">📁</div>
            <div class="card-header-info">
              <div class="card-title">Unrestricted File Upload</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A04:2021</span>
                <span class="risk-badge risk-high">HIGH</span>
                <span class="owasp-tag">CWE-434</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              File uploads have no MIME type validation and preserve the original filename.
              Upload HTML/SVG files with scripts, then visit <code>/uploads/filename</code>
              to execute stored XSS from uploaded files.
            </p>
            <button class="expand-toggle" data-target="upload-details">
              <span class="arrow">▶</span> Attack Scenarios
            </button>
            <div class="expand-content" id="upload-details">
              <div class="info-row"><span class="info-label">Attack</span><span class="info-value">Upload xss.html → /uploads/xss.html runs script</span></div>
              <div class="info-row"><span class="info-label">Attack</span><span class="info-value">Upload shell.svg with embedded JS</span></div>
              <div class="info-row"><span class="info-label">Risk</span><span class="info-value">XSS, file overwrite, path traversal in filename</span></div>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Validate MIME type server-side (not Content-Type header)</li>
                  <li>Rename files to random UUIDs</li>
                  <li>Store uploads outside webroot</li>
                  <li>Scan uploads with antivirus</li>
                </ul>
              </div>
