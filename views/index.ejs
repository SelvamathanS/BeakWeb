        <!-- SSRF -->
        <div class="vuln-card">
          <div class="card-header">
            <div class="card-icon icon-purple">🌍</div>
            <div class="card-header-info">
              <div class="card-title">Server-Side Request Forgery (SSRF)</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A10:2021</span>
                <span class="risk-badge risk-high">HIGH</span>
                <span class="owasp-tag">CWE-918</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              The server fetches any URL provided by the user without validation. Attackers can
              use this to access internal services, cloud metadata endpoints, or probe localhost.
            </p>
            <button class="expand-toggle" data-target="ssrf-details">
              <span class="arrow">▶</span> Attack Surface & Payloads
            </button>
            <div class="expand-content" id="ssrf-details">
              <div class="info-row"><span class="info-label">Endpoint</span><span class="info-value">POST /fetch</span></div>
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="ssrf-url">http://localhost:3000/api</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssrf-url">http://127.0.0.1:3000/api/admin</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssrf-url">http://169.254.169.254/latest/meta-data/</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="ssrf-url">file:///etc/passwd</span>
                  <button class="copy-btn">📋</button>
                </li>
              </ul>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Allowlist permitted hostnames/IPs</li>
                  <li>Block private IP ranges (RFC1918)</li>
                  <li>Block loopback / metadata endpoints</li>
                  <li>Use DNS rebinding protection</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-group">
              <label class="form-label">Target URL (server will fetch this)</label>
              <input class="form-input" id="ssrf-url" placeholder="http://localhost:3000/api" value="http://localhost:3000/api/info" />
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="doSSRF()">🌍 Fetch (Server-Side)</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('ssrf-url','http://127.0.0.1:3000/api/admin')">Internal</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('ssrf-url','http://169.254.169.254/latest/meta-data/')">AWS Meta</button>
