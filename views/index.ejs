              <div class="response-status"><span>Status:</span><span class="response-status-text">—</span></div>
              <div class="response-body"></div>
            </div>
          </div>
        </div>

        <!-- Prototype Pollution -->
        <div class="vuln-card" id="proto-section">
          <div class="card-header">
            <div class="card-icon icon-yellow">⛓️</div>
            <div class="card-header-info">
              <div class="card-title">Prototype Pollution</div>
              <div class="card-meta">
                <span class="owasp-tag">OWASP A08:2021</span>
                <span class="risk-badge risk-medium">MEDIUM</span>
                <span class="owasp-tag">CWE-1321</span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <p class="card-description">
              A custom <code>deepMerge()</code> function does not block <code>__proto__</code>
              or <code>constructor.prototype</code> keys, allowing attackers to modify
              <code>Object.prototype</code> globally.
            </p>
            <button class="expand-toggle" data-target="proto-details">
              <span class="arrow">▶</span> Payloads
            </button>
            <div class="expand-content" id="proto-details">
              <ul class="payload-list">
                <li class="payload-item">
                  <span class="payload-code" data-target="proto-input">{"__proto__": {"isAdmin": true}}</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="proto-input">{"__proto__": {"role": "admin", "polluted": "yes"}}</span>
                  <button class="copy-btn">📋</button>
                </li>
                <li class="payload-item">
                  <span class="payload-code" data-target="proto-input">{"constructor": {"prototype": {"admin": true}}}</span>
                  <button class="copy-btn">📋</button>
                </li>
              </ul>
              <div class="mitigation-panel">
                <div class="mitigation-title">✅ Mitigations</div>
                <ul class="mitigation-list">
                  <li>Block __proto__, constructor, prototype keys</li>
                  <li>Use Object.create(null) for safe objects</li>
                  <li>Use structuredClone() for deep copying</li>
                  <li>Use Object.freeze(Object.prototype)</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="card-try">
            <div class="try-label">🧪 Try It</div>
            <div class="form-group">
              <label class="form-label">JSON Payload (merged via vulnerable deepMerge)</label>
              <textarea class="form-textarea" id="proto-input">{"theme": "light"}</textarea>
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="doProtoPollute()">⛓️ Merge</button>
              <button class="btn btn-ghost btn-sm" onclick="setInputValue('proto-input','{\"__proto__\": {\"isAdmin\": true}}')">Pollute</button>
              <button class="btn btn-danger btn-sm" onclick="resetProto()">Reset</button>
            </div>
            <div class="response-viewer" id="proto-response">
              <div class="response-tabs"><button class="response-tab active">Response</button></div>
              <div class="response-status"><span>Status:</span><span class="response-status-text">—</span></div>
              <div class="response-body"></div>
            </div>
          </div>
        </div>

        <!-- Code Injection -->
